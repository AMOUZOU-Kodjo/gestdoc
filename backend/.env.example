# ================================
# GestDoc Backend — Variables d'environnement
# ================================
# IMPORTANT: Copiez ce fichier en .env et remplissez les valeurs
# Ne committez JAMAIS le fichier .env dans git !

# Base de données PostgreSQL (Neon.tech recommandé)
DATABASE_URL="postgresql://USERNAME:PASSWORD@HOST/DATABASE?sslmode=require"

# JWT Secrets — Générez avec: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="votre_secret_jwt_tres_long_et_aleatoire_min_64_chars"
JWT_REFRESH_SECRET="votre_secret_refresh_different_du_jwt_secret_min_64_chars"

# Cloudinary (compte gratuit sur cloudinary.com)
CLOUDINARY_CLOUD_NAME="votre_cloud_name"
CLOUDINARY_API_KEY="votre_api_key"
CLOUDINARY_API_SECRET="votre_api_secret"

# URL du frontend (pour CORS)
FRONTEND_URL="http://localhost:5173"
# En production: FRONTEND_URL="https://votre-app.vercel.app"

# Port (Render l'injecte automatiquement)
PORT=5000

# Environnement
NODE_ENV="development"
# En production: NODE_ENV="production"
