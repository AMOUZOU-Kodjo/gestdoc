generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ENSEIGNANT
  ADMIN
}

enum UserProfile {
  BEPC
  PREMIERE
  TERMINALE
  UNIVERSITE
  ENSEIGNANT
  ADMIN
}

enum DocumentStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id           String       @id @default(uuid())
  nom          String
  prenom       String
  email        String       @unique
  passwordHash String       @map("password_hash")
  role         Role         @default(USER)
  profile      UserProfile?
  avatarUrl    String?      @map("avatar_url")
  isActive     Boolean      @default(true) @map("is_active")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  documents     Document[]
  downloads     Download[]
  refreshTokens RefreshToken[]
  loginAttempts LoginAttempt[]
  forumPosts    ForumPost[]
  forumReplies  ForumReply[]
  forumLikes    ForumLike[]
  subscription  Subscription?
  downloadQuota Int      @default(0) @map("download_quota") // bonus uploads validés

  @@map("users")
}

model Document {
  id            String         @id @default(uuid())
  titre         String
  description   String?
  classe        String
  matiere       String
  annee         Int
  niveau        String
  fileUrl       String         @map("file_url")
  fileType      String         @map("file_type")
  fileSize      Int?           @map("file_size")
  publicId      String?        @map("public_id")
  status        DocumentStatus @default(PENDING)
  downloadCount Int            @default(0) @map("download_count")
  uploaderId    String         @map("uploader_id")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  uploader  User       @relation(fields: [uploaderId], references: [id], onDelete: Cascade)
  downloads Download[]

  @@index([niveau, classe, matiere, annee])
  @@index([status])
  @@map("documents")
}

model Download {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  documentId   String   @map("document_id")
  downloadedAt DateTime @default(now()) @map("downloaded_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@map("downloads")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model SiteSettings {
  id              String   @id @default("singleton")
  siteName        String   @default("GestDoc")              @map("site_name")
  siteDescription String   @default("Plateforme de partage de documents scolaires") @map("site_description")
  contactEmail    String   @default("contact@gestdoc.tg")   @map("contact_email")
  contactPhone    String   @default("+228 90 00 00 00")     @map("contact_phone")
  contactAddress  String   @default("Lomé, Togo")           @map("contact_address")
  facebookUrl     String   @default("")                     @map("facebook_url")
  twitterUrl      String   @default("")                     @map("twitter_url")
  instagramUrl    String   @default("")                     @map("instagram_url")
  youtubeUrl      String   @default("")                     @map("youtube_url")
  maintenanceMode Boolean  @default(false)                  @map("maintenance_mode")
  allowUploads    Boolean  @default(true)                   @map("allow_uploads")
  maxFileSizeMb   Int      @default(20)                     @map("max_file_size_mb")
  donActif        Boolean  @default(false)                  @map("don_actif")
  donTitre        String   @default("Soutenez GestDoc 💙")  @map("don_titre")
  donMessage      String   @default("Votre don nous aide à maintenir la plateforme.") @map("don_message")
  donNumero       String   @default("")                     @map("don_numero")
  donNom          String   @default("")                     @map("don_nom")
  donMontants     String   @default("500,1000,2000,5000")   @map("don_montants")
  updatedAt       DateTime @updatedAt                       @map("updated_at")

  @@map("site_settings")
}

model ForumPost {
  id        String   @id @default(uuid())
  titre     String
  contenu   String
  userId    String   @map("user_id")
  niveau    String?
  views     Int      @default(0)
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  replies ForumReply[]
  likes   ForumLike[]

  @@index([niveau])
  @@index([createdAt])
  @@map("forum_posts")
}

model ForumReply {
  id        String   @id @default(uuid())
  contenu   String
  userId    String   @map("user_id")
  postId    String   @map("post_id")
  parentId  String?  @map("parent_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  post     ForumPost    @relation(fields: [postId], references: [id], onDelete: Cascade)
  parent   ForumReply?  @relation("ReplyToReply", fields: [parentId], references: [id], onDelete: SetNull)
  children ForumReply[] @relation("ReplyToReply")

  @@map("forum_replies")
}

model ForumLike {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  postId    String   @map("post_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  post ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@map("forum_likes")
}

model Subscription {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  actif     Boolean  @default(true)
  debut     DateTime @default(now()) @map("debut")
  fin       DateTime @map("fin")
  montant   Int
  reference String?
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model LoginAttempt {
  id          String   @id @default(uuid())
  email       String
  ipAddress   String   @map("ip_address")
  success     Boolean
  attemptedAt DateTime @default(now()) @map("attempted_at")
  userId      String?  @map("user_id")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("login_attempts")
}
